def chkvec(a, b):

    # Create a hash set and insert all elements of arr1
    hash_set = set(a)

    # Check each element of arr2 in the hash set
    for num in b:
        if num not in hash_set:
            return False

    # If all elements of arr2 are found in the hash set
    return True

def Zedge(Z):
    dZsx = [0.0]*len(Z)
    dZdx = [0.0]*len(Z)
    for k in range(len(Z)):
        dcen = Z[k]
        if(k < len(Z)-1):
            dup = Z[k+1]
        else:
            dup = Z[k] * 1.1

        if(k > 0):
            dlow = Z[k-1]
        else:
            dlow = 0.9 * Z[k]

        dZsx[k] = (dcen-dlow)/2.0
        dZdx[k] = (dup-dcen)/2.0

    return dZsx, dZdx

