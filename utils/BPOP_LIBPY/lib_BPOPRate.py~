def tgw(m1,m2,a,e):

    cl = 3.E8
    G  = 6.67E-11
    Ms = 1.99E30
    Rs = 1.5E11
    
    tgw = 256./5. * pow(cl,5.) * pow(a * Rs,4.) * pow(G*Ms,-3.) /(m1*m2*(m1+m2)) * pow(1.-e*e,3.5)
    tgw = tgw /(365.*24.*3600.)
   
    return tgw


def DtDz(zz, H0now, Omatt, Olamb):
    dtdz_now = (1.+zz) * H0now * ( 1.E3 / 3.08E22 * 365.*24.*3600. ) * np.sqrt(pow(1.+zz,3.)*Omatt + Olamb)
    return 1./dtdz_now



