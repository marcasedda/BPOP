def comdis(z, H0, OmegaM, OmegaL, c):
    A = c/H0 * 1. / np.sqrt(pow(1.+z,3.)*OmegaM + OmegaL) 
    return A


def volume(Da, z, H0, OmegaM, OmegaL, c):  
    dVdz = (4.*np.pi) * (c/H0)  * (Da*Da) / (np.sqrt(pow(1.+z,3.)*OmegaM + OmegaL))
    return dVdz

