CXX = g++

RESULT   = BPOP.x
CXXFLAGS = -O3 -I../include
LDFLAGS = -o $(RESULT)

VPATH= ../:../src/Main:../include

INC = input_params.h funcGR.h
SOURCE = Main_Bpop_dev.cpp funcGR.cpp

.SUFFIXES : .o .cpp

OBJECTS = $(SOURCE:.cpp=.o)

TARGET: $(RESULT) 

$(RESULT): $(OBJECTS)
	$(CXX) $(CXXFLAGS) $(LDFLAGS)  $(OBJECTS)

